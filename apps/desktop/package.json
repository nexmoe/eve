{
  "name": "eve-desktop",
  "productName": "eve",
  "version": "0.5.11",
  "description": "Desktop app for eve.",
  "author": "nexmoe",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "bun run typecheck && electron-vite build",
    "build:mac": "bun run build && bun run prepare:shared-runtime && electron-builder --mac --publish never",
    "build:win": "bun run build && bun run prepare:shared-runtime && electron-builder --win --publish never",
    "cli": "electron-vite dev -- --cli",
    "dev": "electron-vite dev",
    "lint": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "prepare:shared-runtime": "node ./scripts/prepare-shared-python-runtime.mjs",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "typecheck": "bun run lint"
  },
  "dependencies": {
    "@eve/shared": "workspace:*",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "electron-log": "^5.4.3",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.542.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
